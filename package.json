{
  "name": "thaitype-stack-spa-react-elysia-prisma-template",
  "description": "Full-stack Todo app template with Next.js, Elysia, Prisma, and Better Auth",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*",
    "#generated/*": "./generated/*",
    "#/*": "./app/*"
  },
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"bun run dev:frontend\" \"bun run dev:server\"",
    "dev:frontend": "next dev --port 3000",
    "dev:server": "bun run --watch server/index.ts",
    "start": "concurrently -n frontend,backend -c cyan,magenta \"bun run start:frontend\" \"bun run start:server\"",
    "start:frontend": "cross-env NODE_ENV=production next start --port 3000",
    "start:server": "cross-env NODE_ENV=production bun run server/index.ts",
    "build": "next build",
    "build:all": "bunx prisma generate && next build",
    "preview": "next start --port 3000",
    "test": "vitest run",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:seed-admin": "bun run scripts/seed-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/static": "^1.4.7",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.95.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "elysia": "^1.4.28",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "prismabox": "^1.1.26",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
